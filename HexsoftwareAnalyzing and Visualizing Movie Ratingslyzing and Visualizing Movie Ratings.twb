    <worksheet name='Sheet 2'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontalignment='1' fontcolor='#000000' fontname='Imprint MT Shadow' fontsize='16'>Top 10 Rated Movies</run>
            <run fontalignment='1' fontcolor='#ffffff' fontname='Imprint MT Shadow' fontsize='16'> 10 Rated Movies</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='imdb_top_1000' name='federated.0x24gep1h6g8de16g1kw50ea93to' />
          </datasources>
          <datasource-dependencies datasource='federated.0x24gep1h6g8de16g1kw50ea93to'>
            <column caption='IMDB Rating' datatype='real' name='[IMDB_Rating]' role='measure' type='quantitative' />
            <column caption='Series Title' datatype='string' name='[Series_Title]' role='dimension' type='nominal' />
            <column-instance column='[IMDB_Rating]' derivation='Max' name='[max:IMDB_Rating:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Series_Title]' derivation='None' name='[none:Series_Title:nk]' pivot='key' type='nominal' />
            <column-instance column='[IMDB_Rating]' derivation='Sum' name='[sum:IMDB_Rating:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.0x24gep1h6g8de16g1kw50ea93to].[none:Series_Title:nk]'>
            <groupfilter count='10' end='top' function='end' units='records' user:ui-marker='end' user:ui-top-by-field='true'>
              <groupfilter direction='DESC' expression='MAX([IMDB_Rating])' function='order' user:ui-marker='order'>
                <groupfilter function='union' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate'>
                  <groupfilter function='member' level='[none:Series_Title:nk]' member='&quot;(500) Days of Summer&quot;' />
                  <groupfilter function='member' level='[none:Series_Title:nk]' member='&quot;12 Angry Men&quot;' />
                  <groupfilter function='member' level='[none:Series_Title:nk]' member='&quot;12 Years a Slave&quot;' />
                  <groupfilter function='member' level='[none:Series_Title:nk]' member='&quot;1917&quot;' />
                  <groupfilter function='member' level='[none:Series_Title:nk]' member='&quot;2001: A Space Odyssey&quot;' />
                  <groupfilter function='member' level='[none:Series_Title:nk]' member='&quot;21 Grams&quot;' />
                  <groupfilter function='member' level='[none:Series_Title:nk]' member='&quot;25th Hour&quot;' />
                  <groupfilter function='member' level='[none:Series_Title:nk]' member='&quot;28 Days Later...&quot;' />
                  <groupfilter function='member' level='[none:Series_Title:nk]' member='&quot;3 Idiots&quot;' />
                  <groupfilter function='member' level='[none:Series_Title:nk]' member='&quot;3:10 to Yuma&quot;' />
